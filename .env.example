# API Configuration
# Copy this file to .env and fill in your actual bearer tokens
# NEVER commit .env to version control!

# TeamBook API Bearer Token
TEAMBOOK_BEARER_TOKEN=your_teambook_bearer_token_here

# DataSight API Bearer Token
DATASIGHT_BEARER_TOKEN=your_datasight_bearer_token_here

# Database Configuration
DB_PATH=metrics.db

# Service Line
SERVICE_LINE_ID=449

# Data Retention
MAX_WEEKS_TO_KEEP=5

# Refresh Settings
AUTO_REFRESH_ENABLED=false
REFRESH_INTERVAL_HOURS=168
